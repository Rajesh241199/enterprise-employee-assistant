APP_NAME=Enterprise Employee Knowledge Assistant
APP_ENV=local
APP_DEBUG=true
APP_UPLOAD_DIR=storage/uploads

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/employee_assistant

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=employee_knowledge

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

OCR_ENABLED=true
OCR_DPI=200
OCR_MIN_TEXT_CHARS_PER_PAGE=50
OCR_LANGUAGE=eng
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

JWT_SECRET_KEY=change-this-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60