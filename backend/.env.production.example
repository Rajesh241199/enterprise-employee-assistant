APP_NAME=Internal Employee Assistant
APP_ENV=production
APP_DEBUG=false

DATABASE_URL=postgresql://postgres:replace-with-strong-db-password@postgres:5432/employee_assistant

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=employee_knowledge

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2:3b

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

JWT_SECRET_KEY=replace-with-a-long-random-production-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OCR_ENABLED=true
OCR_DPI=200
OCR_MIN_TEXT_CHARS_PER_PAGE=50
OCR_LANGUAGE=eng
TESSERACT_CMD=/usr/bin/tesseract

CORS_ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP,http://YOUR_EC2_PUBLIC_IP:80

RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_REQUESTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60

MAX_REQUEST_BODY_BYTES=10485760
MAX_UPLOAD_FILE_BYTES=10485760

APP_LOG_DIR=logs
APP_LOG_FILE=logs/app.log
APP_ERROR_LOG_FILE=logs/error.log
APP_AUDIT_LOG_FILE=logs/audit.jsonl
SLOW_REQUEST_THRESHOLD_MS=1500